From 923f0fbeecd0d8689c08315f88188ac00746570b Mon Sep 17 00:00:00 2001
From: Mohd Ayaan Anwar <mohd.anwar@oss.qualcomm.com>
Date: Mon, 30 Mar 2026 01:22:43 +0530
Subject: [PATCH 06/12] net: ethernet: tc956x: Use kernel_ethtool_ts_info
 (kernel 6.11)

struct ethtool_ts_info was renamed to kernel_ethtool_ts_info in
kernel 6.11.  Update the get_ts_info callback signature accordingly.

Upstream-Status: Submitted [https://github.com/TC956X/TC9564_Host_Driver/pull/4]
Signed-off-by: Mohd Ayaan Anwar <mohd.anwar@oss.qualcomm.com>
---
 drivers/net/ethernet/toshiba/tc956x/tc956xmac_ethtool.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/ethernet/toshiba/tc956x/tc956xmac_ethtool.c b/drivers/net/ethernet/toshiba/tc956x/tc956xmac_ethtool.c
index b8ada47..944eb32 100644
--- a/drivers/net/ethernet/toshiba/tc956x/tc956xmac_ethtool.c
+++ b/drivers/net/ethernet/toshiba/tc956x/tc956xmac_ethtool.c
@@ -2403,7 +2403,7 @@ static int tc956xmac_set_rxfh(struct net_device *dev, const u32 *indir,
 #endif
 
 static int tc956xmac_get_ts_info(struct net_device *dev,
-			      struct ethtool_ts_info *info)
+			      struct kernel_ethtool_ts_info *info)
 {
 	struct tc956xmac_priv *priv = netdev_priv(dev);
 
-- 
2.34.1

