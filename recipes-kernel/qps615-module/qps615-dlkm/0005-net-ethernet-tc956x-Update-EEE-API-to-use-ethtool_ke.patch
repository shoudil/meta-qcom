 .../toshiba/tc956x/tc956xmac_ethtool.c        | 53 ++++++++++---------
 .../ethernet/toshiba/tc956x/tc956xmac_main.c  |  8 +--
 4 files changed, 39 insertions(+), 38 deletions(-)

