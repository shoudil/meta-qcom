From b9fb9ea6fc41bd52688b55772fba9d760d8c92a3 Mon Sep 17 00:00:00 2001
From: Mohd Ayaan Anwar <mohd.anwar@oss.qualcomm.com>
Date: Mon, 30 Mar 2026 01:23:17 +0530
Subject: [PATCH 10/12] net: ethernet: tc956x: Use kvfree() instead of vfree()

kernel_read_file_from_path() may return either vmalloc'd or kmalloc'd
memory depending on the kernel version.  Use kvfree() which handles
both cases correctly.

Upstream-Status: Submitted [https://github.com/TC956X/TC9564_Host_Driver/pull/4]
Signed-off-by: Mohd Ayaan Anwar <mohd.anwar@oss.qualcomm.com>
---
 drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c b/drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c
index 4385889..8274191 100644
--- a/drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c
+++ b/drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c
@@ -15335,7 +15335,7 @@ static void parse_config_file(uint8_t port_id, uint8_t dev_id)
 		}
 	}
 
-	vfree(data);
+	kvfree(data);
 	KPRINT_INFO("<--%s", __func__);
 }
 #endif
-- 
2.34.1

