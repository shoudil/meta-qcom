From 4db8dc48880db92d237fb144433f54545629e4af Mon Sep 17 00:00:00 2001
From: Mohd Ayaan Anwar <mohd.anwar@oss.qualcomm.com>
Date: Mon, 30 Mar 2026 01:22:51 +0530
Subject: [PATCH 07/12] net: ethernet: tc956x: Use hrtimer_setup() (kernel
 6.15)

The two-step hrtimer_init() + function-pointer assignment was replaced
by the combined hrtimer_setup() helper in kernel 6.15.

Upstream-Status: Submitted [https://github.com/TC956X/TC9564_Host_Driver/pull/4]
Signed-off-by: Mohd Ayaan Anwar <mohd.anwar@oss.qualcomm.com>
---
 drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c b/drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c
index d310753..23d283a 100644
--- a/drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c
+++ b/drivers/net/ethernet/toshiba/tc956x/tc956xmac_main.c
@@ -6643,8 +6643,7 @@ static void tc956xmac_init_coalesce(struct tc956xmac_priv *priv)
 			continue;
 #endif
 #if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 11, 0)
-		hrtimer_init(&tx_q->txtimer, CLOCK_MONOTONIC, HRTIMER_MODE_REL);
-		tx_q->txtimer.function = tc956xmac_tx_timer;
+		hrtimer_setup(&tx_q->txtimer, tc956xmac_tx_timer, CLOCK_MONOTONIC, HRTIMER_MODE_REL);
 #else
 		timer_setup(&tx_q->txtimer, tc956xmac_tx_timer, 0);
 #endif
-- 
2.34.1

